rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    // User profile images
    match /users/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // App profile image uploads (current client path)
    match /user-profile-images/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // District assets (uploaded via vision quest, etc)
    match /districts/{districtId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Simplified for hackathon
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

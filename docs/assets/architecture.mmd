    classDef client fill:#0B0F19,stroke:#3B82F6,stroke-width:2px,color:#FFFFFF,rx:12,ry:12;
    classDef ai fill:#0B0F19,stroke:#A855F7,stroke-width:2px,color:#FFFFFF,rx:12,ry:12;
    classDef backend fill:#0B0F19,stroke:#10B981,stroke-width:2px,color:#FFFFFF,rx:12,ry:12;

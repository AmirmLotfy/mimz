flowchart LR
    subgraph Client ["Client Layer (Flutter)"]
        direction TB
        App["📱 iOS & Android App<br/>(Riverpod + Audio)"]
    end

    subgraph Intelligence ["AI Layer (Google)"]
        direction TB
        Gemini{"🧠 Gemini 2.0<br/>Flash Live API"}
    end

    subgraph Backend ["Logic Layer (Cloud Run)"]
        direction TB
        API["📡 Fastify REST API<br/>(Node.js + TypeScript)"]
        Tools["⚙️ Tool Validator<br/>(Zod Parsing)"]
    end

    subgraph Data ["Data Layer (Firebase)"]
        direction TB
        Auth["🔐 Firebase Auth"]
        DB[("🗄️ Cloud Firestore")]
    end

    %% Communication Flows
    App <-->|"1. Bidirectional WebSocket<br/>(Realtime Voice)"| Gemini
    Gemini -.->|"2. Emit Tool Intent<br/>(e.g., grade_answer)"| App
    
    App -->|"3. HTTPS POST<br/>(Tool Execution)"| API
    
    API -->|"4. Verify Token"| Auth
    API -->|"5. Process Tool"| Tools
    Tools -->|"6. Authoritative Write"| DB
    Tools -.->|"7. Return New Game State"| App

    %% Enterprise Styling
    classDef clientNode fill:#0F172A,stroke:#3B82F6,stroke-width:2px,color:#F8FAFC,rx:8,ry:8;
    classDef aiNode fill:#0F172A,stroke:#8B5CF6,stroke-width:2px,color:#F8FAFC,rx:8,ry:8;
    classDef backendNode fill:#0F172A,stroke:#10B981,stroke-width:2px,color:#F8FAFC,rx:8,ry:8;
    classDef dataNode fill:#0F172A,stroke:#F59E0B,stroke-width:2px,color:#F8FAFC,rx:8,ry:8;

    class App clientNode;
    class Gemini aiNode;
    class API,Tools backendNode;
    class Auth,DB dataNode;

    style Client fill:#0B1120,stroke:#1E293B,stroke-width:2px,color:#94A3B8,rx:12,ry:12
    style Intelligence fill:#0B1120,stroke:#1E293B,stroke-width:2px,color:#94A3B8,rx:12,ry:12
    style Backend fill:#0B1120,stroke:#1E293B,stroke-width:2px,color:#94A3B8,rx:12,ry:12
    style Data fill:#0B1120,stroke:#1E293B,stroke-width:2px,color:#94A3B8,rx:12,ry:12

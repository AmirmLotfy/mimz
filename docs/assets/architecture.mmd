    style Client fill:#3B82F60A,stroke:#3B82F633,stroke-width:1.5px,rx:20,ry:20,stroke-dasharray: 5 5
    style Intelligence fill:#A855F70A,stroke:#A855F733,stroke-width:1.5px,rx:20,ry:20,stroke-dasharray: 5 5
    style Backend fill:#10B9810A,stroke:#10B98133,stroke-width:1.5px,rx:20,ry:20,stroke-dasharray: 5 5
    style Data fill:#F59E0B0A,stroke:#F59E0B33,stroke-width:1.5px,rx:20,ry:20,stroke-dasharray: 5 5

    subgraph Client ["<b>📲 Client Layer (Flutter)</b>"]
        direction TB
        App(("<b>iOS & Android App</b><br/><span style='font-size:13px;color:#9CA3AF;font-weight:400'>Riverpod + Live Audio</span>"))
    end

    subgraph Intelligence ["<b>🧠 Intelligence Layer (Google)</b>"]
        direction TB
        Gemini[/"<b>Gemini 2.5</b><br/><span style='font-size:13px;color:#9CA3AF;font-weight:400'>Flash Native Audio API</span>"\]
    end

    subgraph Backend ["<b>⚡ Logic Layer (Cloud Run)</b>"]
        direction TB
        API[("<b>Fastify API</b><br/><span style='font-size:13px;color:#9CA3AF;font-weight:400'>Node.js + TypeScript</span>")]
        Tools{{"<b>Execution Engine</b><br/><span style='font-size:13px;color:#9CA3AF;font-weight:400'>Zod Validation</span>"}}
        API --- Tools
    end

    subgraph Data ["<b>🗄️ Data Layer (Firebase)</b>"]
        direction TB
        Auth>"<b>Firebase Auth</b>"]
        DB[("<b>Firestore</b><br/><span style='font-size:13px;color:#9CA3AF;font-weight:400'>Realtime persistence</span>")]
    end

    App -->|"<b>1. Bidirectional WebSocket</b><br/>Realtime Voice + Vision"| Gemini
    Gemini -.->|"<b>2. Tool Call Intent</b><br/>e.g., grade_answer"| App
    
    App -->|"<b>3. HTTPS POST</b><br/>Execute Tool Request"| API
    
    API -.->|"<b>4. Verify JWT</b>"| Auth
    Tools -->|"<b>5. Authoritative Write</b>"| DB
    Tools -.->|"<b>6. Return New State</b>"| App

    class App client
    class Gemini ai
    class API,Tools backend
    class Auth,DB data
    

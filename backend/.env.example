# ─── Backend Environment Variables ─────────────────────
# Copy to .env and fill in values.
# NEVER commit your real .env file.

# Server
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Firebase / Google Cloud
GCP_PROJECT_ID=mimz-your-project-id
FIREBASE_PROJECT_ID=mimz-your-project-id
FIRESTORE_DATABASE=(default)
STORAGE_BUCKET=mimz-your-project-id.appspot.com

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001
GEMINI_UTILITY_MODEL=gemini-2.5-flash-lite

# Token settings
EPHEMERAL_TOKEN_TTL_MS=300000

# Abuse protection
MAX_REWARD_PER_HOUR=5000
MAX_SECTORS_PER_ROUND=3
MAX_STREAK_BONUS=10

# Local development (uncomment if using emulators)
# FIRESTORE_EMULATOR_HOST=localhost:8081
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

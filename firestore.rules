rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      // Anyone can read (for leaderboards/squads), only owner can write
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId);
      allow delete: if false; // Soft deletes handled by backend
    }

    // Districts collection
    match /districts/{districtId} {
      allow read: if isAuthenticated();
      // Modifications should generally happen via backend, but we allow owner for now
      allow create, update: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow delete: if false;
    }

    // Squads collection
    match /squads/{squadId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // More granular rules needed for prod
      allow delete: if false;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
